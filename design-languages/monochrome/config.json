      "16": "4rem",
      "20": "5rem",
      "24": "6rem",
      "32": "8rem"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": ["Helvetica Neue", "Helvetica", "Arial", "sans-serif"],
      "serif": ["Georgia", "Times New Roman", "serif"],
      "mono": ["Menlo", "Monaco", "Courier New", "monospace"]
    },
    "fontSize": {
