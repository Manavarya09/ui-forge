      "destructiveForeground": "#ffffff",
      "card": "#ffffff",
      "cardForeground": "#0a0a0a",
      "popover": "#ffffff",
      "popoverForeground": "#0a0a0a",
      "gray50": "#fafafa",
      "gray100": "#f5f5f5",
      "gray200": "#e5e5e5",
      "gray300": "#d4d4d4",
      "gray400": "#a3a3a3",
