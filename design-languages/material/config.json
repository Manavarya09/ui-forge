{
  "name": "material",
  "description": "Layered UI, clear hierarchy, consistent spacing system",
  "tokens": {
    "colors": {
      "background": "#ffffff",
      "foreground": "#202124",
      "primary": "#1976d2",
      "primaryForeground": "#ffffff",
      "secondary": "#f1f3f4",
      "secondaryForeground": "#5f6368",
      "muted": "#f8f9fa",
      "mutedForeground": "#80868b",
      "accent": "#ea4335",
      "accentForeground": "#ffffff",
      "border": "#dadce0",
      "ring": "#1976d2",
      "destructive": "#d32f2f",
      "destructiveForeground": "#ffffff",
      "card": "#ffffff",
      "cardForeground": "#202124",
      "popover": "#ffffff",
      "popoverForeground": "#202124",
      "surface": "#ffffff",
      "surfaceVariant": "#f1f3f4",
      "outline": "#dadce0"
    },
    "borderRadius": {
      "none": "0",
      "sm": "4px",
      "DEFAULT": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "full": "9999px"
    },
    "spacing": {
      "0": "0",
      "1": "0.25rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "4": "1rem",
      "5": "1.25rem",
      "6": "1.5rem",
      "8": "2rem",
      "10": "2.5rem",
      "12": "3rem",
      "16": "4rem",
      "20": "5rem",
      "24": "6rem",
      "32": "8rem"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": ["Roboto", "system-ui", "sans-serif"],
      "serif": ["Roboto Slab", "Georgia", "serif"],
      "mono": ["Roboto Mono", "monospace"]
    },
    "fontSize": {
      "xs": ["0.75rem", { "lineHeight": "1rem" }],
      "sm": ["0.875rem", { "lineHeight": "1.25rem" }],
      "base": ["1rem", { "lineHeight": "1.5rem" }],
      "lg": ["1.125rem", { "lineHeight": "1.75rem" }],
      "xl": ["1.25rem", { "lineHeight": "1.75rem" }],
      "2xl": ["1.5rem", { "lineHeight": "2rem" }],
      "3xl": ["2rem", { "lineHeight": "2.25rem" }],
      "4xl": ["2.5rem", { "lineHeight": "2.5rem" }],
      "5xl": ["3rem", { "lineHeight": "1.1" }],
      "6xl": ["3.75rem", { "lineHeight": "1" }],
      "7xl": ["4.5rem", { "lineHeight": "1" }],
      "8xl": ["6rem", { "lineHeight": "1" }],
      "9xl": ["8rem", { "lineHeight": "1" }]
    },
    "fontWeight": {
      "thin": "300",
      "light": "300",
      "normal": "400",
      "medium": "500",
      "semibold": "500",
      "bold": "700",
      "extrabold": "700",
      "black": "900"
    },
    "letterSpacing": {
      "tighter": "-0.01em",
      "tight": "-0.005em",
      "normal": "0em",
      "wide": "0.01em",
      "wider": "0.02em",
      "widest": "0.05em"
    }
  },
  "effects": {
    "shadows": {
      "none": "none",
      "sm": "0 1px 2px rgba(0, 0, 0, 0.3), 0 1px 3px 1px rgba(0, 0, 0, 0.15)",
      "DEFAULT": "0 1px 3px 0 rgba(0, 0, 0, 0.3), 0 4px 8px 3px rgba(0, 0, 0, 0.15)",
      "md": "0 4px 4px 0 rgba(0, 0, 0, 0.3), 0 8px 16px 4px rgba(0, 0, 0, 0.15)",
      "lg": "0 8px 4px 0 rgba(0, 0, 0, 0.3), 0 16px 32px 8px rgba(0, 0, 0, 0.15)",
      "xl": "0 8px 4px 0 rgba(0, 0, 0, 0.3), 0 24px 48px 12px rgba(0, 0, 0, 0.15)"
    },
    "gradients": {
      "surface": "linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(0, 0, 0, 0.02) 100%)"
    },
    "blur": {},
    "transitions": {
      "DEFAULT": "all 200ms ease-out",
      "fast": "all 100ms ease-out",
      "slow": "all 300ms ease-out",
      "emerging": "all 250ms cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },
  "layout": {
    "containerMaxWidth": "1200px",
    "sectionPadding": "4rem 1.5rem",
    "gridGap": "1rem",
    "cardPadding": "1rem",
    "navbarHeight": "3.5rem",
    "elevationSystem": true,
    "surfaceBaseElevation": 1
  }
}
