      "sm": ["0.875rem", { "lineHeight": "1.1rem" }],
      "base": ["1rem", { "lineHeight": "1.2rem" }],
      "lg": ["1.125rem", { "lineHeight": "1.3rem" }],
      "xl": ["1.25rem", { "lineHeight": "1.3rem" }],
