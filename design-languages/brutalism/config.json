      "lg": "12px 12px 0px #000000",
      "xl": "16px 16px 0px #000000",
      "offset": "4px 4px 0px"
    },
    "gradients": {},
    "blur": {},
    "transitions": {
      "DEFAULT": "all 0ms",
      "fast": "all 0ms",
      "slow": "all 100ms"
    }
