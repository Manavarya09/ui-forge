      "8xl": ["8rem", { "lineHeight": "0.85" }],
      "9xl": ["10rem", { "lineHeight": "0.8" }]
    },
    "fontWeight": {
      "thin": "700",
      "light": "700",
      "normal": "700",
      "medium": "700",
      "semibold": "700",
      "bold": "800",
      "extrabold": "800",
      "black": "900"
    },
    "letterSpacing": {
      "tighter": "-0.03em",
      "tight": "-0.02em",
      "normal": "0em",
      "wide": "0.05em",
      "wider": "0.1em",
      "widest": "0.2em"
    }
