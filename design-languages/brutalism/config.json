    "borderRadius": {
      "none": "0",
      "sm": "0",
      "DEFAULT": "0",
      "md": "0",
      "lg": "0",
      "xl": "0",
      "full": "0"
    },
    "spacing": {
      "0": "0",
      "1": "0.25rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "4": "1rem",
      "5": "1.25rem",
      "6": "1.5rem",
      "8": "2rem",
      "10": "2.5rem",
      "12": "3rem",
      "16": "4rem",
      "20": "5rem",
      "24": "6rem",
      "32": "8rem"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": ["Space Grotesk", "Arial Black", "sans-serif"],
      "serif": ["Archivo Black", "Impact", "serif"],
      "mono": ["Space Mono", "Courier New", "monospace"]
