{
  "name": "swiss",
  "description": "Strong grid system, clean typography, structured alignment",
  "tokens": {
    "colors": {
      "background": "#ffffff",
      "foreground": "#000000",
      "primary": "#000000",
      "primaryForeground": "#ffffff",
      "secondary": "#f0f0f0",
      "secondaryForeground": "#333333",
      "muted": "#e8e8e8",
      "mutedForeground": "#666666",
      "accent": "#ff0000",
      "accentForeground": "#ffffff",
      "border": "#000000",
      "ring": "#ff0000",
      "destructive": "#ff0000",
      "destructiveForeground": "#ffffff",
      "card": "#ffffff",
      "cardForeground": "#000000",
      "popover": "#ffffff",
      "popoverForeground": "#000000",
      "red": "#ff0000",
      "black": "#000000",
      "white": "#ffffff"
    },
    "borderRadius": {
      "none": "0",
      "sm": "0",
      "DEFAULT": "0",
      "md": "0",
      "lg": "0",
      "xl": "0",
      "full": "0"
    },
    "spacing": {
      "0": "0",
      "1": "0.25rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "4": "1rem",
      "5": "1.25rem",
      "6": "1.5rem",
      "8": "2rem",
      "10": "2.5rem",
      "12": "3rem",
      "16": "4rem",
      "20": "5rem",
      "24": "6rem",
      "32": "8rem",
      "40": "10rem",
      "48": "12rem"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": [
        "Akzidenz-Grotesk",
        "Helvetica Neue",
        "Helvetica",
        "Arial",
        "sans-serif"
      ],
      "serif": ["Times New Roman", "Georgia", "serif"],
      "mono": ["Courier New", "Courier", "monospace"]
    },
    "fontSize": {
      "xs": ["0.6875rem", { "lineHeight": "0.875rem" }],
      "sm": ["0.75rem", { "lineHeight": "1rem" }],
      "base": ["0.875rem", { "lineHeight": "1.125rem" }],
      "lg": ["1rem", { "lineHeight": "1.25rem" }],
      "xl": ["1.125rem", { "lineHeight": "1.375rem" }],
      "2xl": ["1.25rem", { "lineHeight": "1.5rem" }],
      "3xl": ["1.5rem", { "lineHeight": "1.75rem" }],
      "4xl": ["2rem", { "lineHeight": "2.25rem" }],
      "5xl": ["2.5rem", { "lineHeight": "2.75rem" }],
      "6xl": ["3rem", { "lineHeight": "3rem" }],
      "7xl": ["3.75rem", { "lineHeight": "3.75rem" }],
      "8xl": ["4.5rem", { "lineHeight": "4.5rem" }],
      "9xl": ["6rem", { "lineHeight": "6rem" }]
    },
    "fontWeight": {
      "thin": "400",
      "light": "400",
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700",
      "extrabold": "800",
      "black": "900"
    },
    "letterSpacing": {
      "tighter": "-0.03em",
      "tight": "-0.02em",
      "normal": "0em",
      "wide": "0.05em",
      "wider": "0.1em",
      "widest": "0.15em"
    }
  },
  "effects": {
    "shadows": {
      "none": "none",
      "sm": "none",
      "DEFAULT": "none",
      "md": "none",
      "lg": "none",
      "xl": "none"
    },
    "gradients": {},
    "blur": {},
    "transitions": {
      "DEFAULT": "all 100ms ease-out",
      "fast": "all 50ms ease-out",
      "slow": "all 200ms ease-out"
    }
  },
  "layout": {
    "containerMaxWidth": "1200px",
    "sectionPadding": "4rem 0",
    "gridGap": "0",
    "cardPadding": "1rem",
    "navbarHeight": "3.5rem",
    "gridSystem": "12-column",
    "strictGrid": true,
    "flushEdges": true,
    "borderBased": true
  }
}
