{
  "name": "tech-futurism",
  "description": "Subtle glow effects, gradients, modern typography, sleek feel",
  "tokens": {
    "colors": {
      "background": "#030712",
      "foreground": "#f9fafb",
      "primary": "#06b6d4",
      "primaryForeground": "#030712",
      "secondary": "#0f172a",
      "secondaryForeground": "#94a3b8",
      "muted": "#0c1222",
      "mutedForeground": "#64748b",
      "accent": "#8b5cf6",
      "accentForeground": "#ffffff",
      "border": "#1e293b",
      "ring": "#06b6d4",
      "destructive": "#ef4444",
      "destructiveForeground": "#ffffff",
      "card": "#0a1628",
      "cardForeground": "#f9fafb",
      "popover": "#0f172a",
      "popoverForeground": "#f9fafb",
      "glowCyan": "#06b6d4",
      "glowPurple": "#8b5cf6",
      "glowPink": "#ec4899"
    },
    "borderRadius": {
      "none": "0",
      "sm": "0.375rem",
      "DEFAULT": "0.5rem",
      "md": "0.75rem",
      "lg": "1rem",
      "xl": "1.5rem",
      "full": "9999px"
    },
    "spacing": {
      "0": "0",
      "1": "0.25rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "4": "1rem",
      "5": "1.25rem",
      "6": "1.5rem",
      "8": "2rem",
      "10": "2.5rem",
      "12": "3rem",
      "16": "4rem",
      "20": "5rem",
      "24": "6rem",
      "32": "8rem"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": ["Orbitron", "Rajdhani", "system-ui", "sans-serif"],
      "serif": ["Exo 2", "Georgia", "serif"],
      "mono": ["Share Tech Mono", "monospace"]
    },
    "fontSize": {
      "xs": ["0.75rem", { "lineHeight": "1rem" }],
      "sm": ["0.875rem", { "lineHeight": "1.25rem" }],
      "base": ["1rem", { "lineHeight": "1.5rem" }],
      "lg": ["1.125rem", { "lineHeight": "1.75rem" }],
      "xl": ["1.25rem", { "lineHeight": "1.75rem" }],
      "2xl": ["1.5rem", { "lineHeight": "2rem" }],
      "3xl": ["1.875rem", { "lineHeight": "2.25rem" }],
      "4xl": ["2.25rem", { "lineHeight": "2.5rem" }],
      "5xl": ["3rem", { "lineHeight": "1.1" }],
      "6xl": ["3.75rem", { "lineHeight": "1" }],
      "7xl": ["4.5rem", { "lineHeight": "1" }],
      "8xl": ["6rem", { "lineHeight": "1" }],
      "9xl": ["8rem", { "lineHeight": "1" }]
    },
    "fontWeight": {
      "thin": "100",
      "light": "300",
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700",
      "extrabold": "800",
      "black": "900"
    },
    "letterSpacing": {
      "tighter": "-0.05em",
      "tight": "-0.025em",
      "normal": "0em",
      "wide": "0.025em",
      "wider": "0.1em",
      "widest": "0.2em"
    }
  },
  "effects": {
    "shadows": {
      "none": "none",
      "sm": "0 0 10px rgba(6, 182, 212, 0.3)",
      "DEFAULT": "0 0 20px rgba(6, 182, 212, 0.4)",
      "md": "0 0 30px rgba(139, 92, 246, 0.4)",
      "lg": "0 0 40px rgba(6, 182, 212, 0.5)",
      "xl": "0 0 60px rgba(139, 92, 246, 0.6)",
      "glow": "0 0 20px",
      "glowMixed": "0 0 40px rgba(6, 182, 212, 0.3), 0 0 60px rgba(139, 92, 246, 0.2)"
    },
    "gradients": {
      "primary": "linear-gradient(135deg, #06b6d4 0%, #8b5cf6 50%, #ec4899 100%)",
      "background": "radial-gradient(ellipse at top, #0a1628 0%, #030712 50%, #000000 100%)",
      "text": "linear-gradient(135deg, #06b6d4 0%, #8b5cf6 100%)",
      "card": "linear-gradient(180deg, rgba(6, 182, 212, 0.05) 0%, rgba(139, 92, 246, 0.05) 100%)",
      "border": "linear-gradient(135deg, rgba(6, 182, 212, 0.3), rgba(139, 92, 246, 0.3))"
    },
    "blur": {
      "sm": "4px",
      "DEFAULT": "8px",
      "md": "12px",
      "lg": "16px",
      "xl": "24px",
      "glow": "40px"
    },
    "transitions": {
      "DEFAULT": "all 300ms cubic-bezier(0.4, 0, 0.2, 1)",
      "fast": "all 150ms cubic-bezier(0.4, 0, 0.2, 1)",
      "slow": "all 500ms cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },
  "layout": {
    "containerMaxWidth": "1400px",
    "sectionPadding": "8rem 1.5rem",
    "gridGap": "2rem",
    "cardPadding": "2rem",
    "navbarHeight": "5rem",
    "futuristic": true,
    "gridLines": false
  }
}
